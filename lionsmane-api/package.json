{
  "name": "lionsmane-api",
  "type": "module",
  "scripts": {
    "dev:api": "bun run --hot src/index.ts",
    "dev:worker": "bun run src/worker.ts",
    "build:api": "bun build ./src/index.ts --outdir ./dist --target bun",
    "build:worker": "bun build ./src/worker.ts --outdir ./dist --target bun",
    "build:all": "bun run build:api && bun run build:worker",
    "test": "vitest",
    "start": "bun --bun dist/index.js"
  },
  "dependencies": {
    "@bull-board/hono": "^6.12.6",
    "@hono/node-server": "^1.19.0",
    "@hono/zod-openapi": "^1.1.0",
    "@mozilla/readability": "^0.6.0",
    "@rowanmanning/feed-parser": "^2.1.1",
    "@scalar/hono-api-reference": "^0.9.16",
    "@types/amqplib": "^0.10.7",
    "better-auth": "^1.3.7",
    "bullmq": "^5.58.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.6",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.5",
    "hono": "^4.9.4",
    "ioredis": "^5.7.0",
    "jsdom": "^26.1.0",
    "pg": "^8.16.3",
    "retext": "^9.0.0",
    "retext-keywords": "^8.0.2",
    "retext-pos": "^5.0.0",
    "uuid": "^11.1.0",
    "zod": "4.1.0"
  },
  "devDependencies": {
    "@eslint/css": "^0.10.0",
    "@eslint/js": "^9.34.0",
    "@eslint/json": "^0.13.1",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.19.11",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.4",
    "globals": "^16.3.0",
    "jiti": "^2.5.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vitest": "^3.2.4"
  }
}
