{
  "openapi": "3.1.0",
  "info": { "title": "lionsmane", "version": "1" },
  "components": {
    "securitySchemes": { "Bearer": { "type": "http", "scheme": "bearer" } },
    "schemas": {
      "NewFeed": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "url": { "type": "string", "minLength": 1, "format": "uri" },
          "description": { "type": ["string", "null"] }
        },
        "required": ["title", "url", "description"]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/v1/feeds": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NewFeed" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Feed created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string", "format": "uuid" },
                    "title": { "type": "string" },
                    "url": {
                      "type": "string",
                      "minLength": 1,
                      "format": "uri"
                    },
                    "description": { "type": ["string", "null"] },
                    "userId": { "type": "string", "format": "uuid" },
                    "updated": { "type": "string", "format": "date" }
                  },
                  "required": [
                    "id",
                    "title",
                    "url",
                    "description",
                    "userId",
                    "updated"
                  ]
                }
              }
            }
          },
          "500": { "description": "Internal error" }
        }
      },
      "get": {
        "responses": {
          "200": {
            "description": "list feeds",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string", "format": "uuid" },
                      "title": { "type": "string" },
                      "url": {
                        "type": "string",
                        "minLength": 1,
                        "format": "uri"
                      },
                      "description": { "type": ["string", "null"] },
                      "userId": { "type": "string", "format": "uuid" },
                      "updated": { "type": "string", "format": "date" }
                    },
                    "required": [
                      "id",
                      "title",
                      "url",
                      "description",
                      "userId",
                      "updated"
                    ]
                  }
                }
              }
            }
          },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/api/v1/feeds/{id}": {
      "get": {
        "parameters": [
          {
            "schema": { "type": "string", "format": "uuid" },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Feed retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string", "format": "uuid" },
                    "title": { "type": "string" },
                    "url": {
                      "type": "string",
                      "minLength": 1,
                      "format": "uri"
                    },
                    "description": { "type": ["string", "null"] },
                    "userId": { "type": "string", "format": "uuid" },
                    "updated": { "type": "string", "format": "date" }
                  },
                  "required": [
                    "id",
                    "title",
                    "url",
                    "description",
                    "userId",
                    "updated"
                  ]
                }
              }
            }
          },
          "404": { "description": "Feed not found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "put": {
        "parameters": [
          {
            "schema": { "type": "string" },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "url": { "type": "string", "minLength": 1, "format": "uri" },
                  "description": { "type": ["string", "null"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Feed updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string", "format": "uuid" },
                    "title": { "type": "string" },
                    "url": {
                      "type": "string",
                      "minLength": 1,
                      "format": "uri"
                    },
                    "description": { "type": ["string", "null"] },
                    "userId": { "type": "string", "format": "uuid" },
                    "updated": { "type": "string", "format": "date" }
                  },
                  "required": [
                    "id",
                    "title",
                    "url",
                    "description",
                    "userId",
                    "updated"
                  ]
                }
              }
            }
          },
          "404": { "description": "Feed not found" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "delete": {
        "parameters": [
          {
            "schema": { "type": "string" },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": { "description": "Feed deleted" },
          "404": { "description": "Feed not found" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
    "/api/v1/articles": {
      "get": {
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "Cursor for pagination, the last article ID from the previous page"
            },
            "required": false,
            "description": "Cursor for pagination, the last article ID from the previous page",
            "name": "cursor",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 10,
              "description": "Number of articles to return per page"
            },
            "required": false,
            "description": "Number of articles to return per page",
            "name": "pageSize",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "List of articles with pagination",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "articles": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "string", "format": "uuid" },
                          "title": { "type": "string", "maxLength": 256 },
                          "url": { "type": "string", "format": "uri" },
                          "authors": {
                            "type": "array",
                            "items": { "type": "string", "maxLength": 256 }
                          },
                          "categories": {
                            "type": "array",
                            "items": { "type": "string", "maxLength": 256 }
                          },
                          "description": {
                            "type": ["string", "null"],
                            "maxLength": 256
                          },
                          "rawContent": { "type": ["string", "null"] },
                          "readableHtml": { "type": ["string", "null"] },
                          "readableText": { "type": ["string", "null"] },
                          "keywords": {
                            "type": "array",
                            "items": { "type": "string", "maxLength": 256 }
                          },
                          "image": {
                            "type": ["string", "null"],
                            "format": "uri"
                          },
                          "media": {
                            "type": "array",
                            "items": { "type": "string", "format": "uri" }
                          },
                          "published": { "type": "string", "format": "date" },
                          "updated": {
                            "type": ["string", "null"],
                            "format": "date"
                          }
                        },
                        "required": [
                          "id",
                          "title",
                          "url",
                          "authors",
                          "categories",
                          "description",
                          "rawContent",
                          "readableHtml",
                          "readableText",
                          "keywords",
                          "image",
                          "media",
                          "published",
                          "updated"
                        ]
                      }
                    },
                    "cursor": { "type": ["string", "null"] }
                  },
                  "required": ["articles"]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/articles/update": {
      "post": {
        "responses": {
          "202": {
            "description": "Articles update initiated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "message": { "type": "string" } },
                  "required": ["message"]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "message": { "type": "string" } },
                  "required": ["message"]
                }
              }
            }
          }
        }
      }
    }
  },
  "webhooks": {}
}
