          },
          "401": {
            "description": "Not Authorized"
          },
          "403": {
            "description": "Not Allowed"
          }
        },
        "summary": "Get All Articles",
        "tags": [
          "Article Resource"
        ],
        "security": [
          {
            "SecurityScheme": []
          }
        ]
